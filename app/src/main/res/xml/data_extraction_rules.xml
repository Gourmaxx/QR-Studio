<?xml version="1.0" encoding="utf-8"?>
<!-- history.json holds Wi-Fi passwords and contacts in clear text; exclude it
     from both cloud backup and device-to-device transfer. The in-app JSON
     export/import is the intended way to move history between devices. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude
            domain="file"
            path="history.json" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="file"
            path="history.json" />
    </device-transfer>
</data-extraction-rules>
